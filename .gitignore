# Nested clone / export scratch (never commit)
ableton-plugin-pipeline/

__pycache__/
*.py[cod]
.DS_Store
.venv/
venv/
.bootstrap_cache/
*.amxd
!tooling/donors/*.amxd

# --- projects/ : public tutorial only; everything else is local (any plugin name) ---
# Sibling folders (e.g. builds without M4L_PROJECTS_PREFIX=workspace) must never be committed.
projects/*/
!projects/Pipeline_Example/
!projects/workspace/

# Local plugin sandboxes (see projects/workspace/README.md)
projects/workspace/*
!projects/workspace/README.md

# Tutorial version folders + binaries are build artifacts (regenerated locally).
projects/Pipeline_Example/Pipeline_Example */

# Local secrets / env (never publish)
.env
.env.*
!.env.example

# Keys / OS cruft
*.pem
Thumbs.db
