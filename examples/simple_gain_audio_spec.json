        "maxclass": "plugin~",
        "numinlets": 1,
        "numoutlets": 1,
        "outlettype": ["signal"],
        "patching_rect": [30.0, 40.0, 80.0, 22.0]
      }
    },
    {
      "box": {
        "id": "obj-out",
        "maxclass": "plugout~",
        "numinlets": 1,
        "numoutlets": 0,
        "patching_rect": [30.0, 120.0, 80.0, 22.0]
      }
    },
    {
      "box": {
        "id": "obj-dial",
        "maxclass": "live.dial",
        "numinlets": 1,
        "numoutlets": 2,
        "outlettype": ["", "float"],
