# Copy to ".env" and load in your shell if your tooling supports it.
# This file is tracked; ".env" is gitignored.

# Required for personal/commercial plugins: keep ALL build output under projects/workspace/
# (gitignored). Do not add your plugin name to .gitignore in this public repo.
M4L_PROJECTS_PREFIX=workspace

# Optional: donor .amxd for packing (see docs/REFERENCE_HEADER_AND_IMPORT.md)
# M4L_REFERENCE_AMXD=/absolute/path/to/Reference.amxd
